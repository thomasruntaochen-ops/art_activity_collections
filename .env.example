APP_NAME=art-activity-collection
APP_ENV=dev
API_HOST=0.0.0.0
API_PORT=8000

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change_me
MYSQL_DB=art_activity_collection
# Optional: set MYSQL_DSN instead of individual MYSQL_* fields.
# MYSQL_DSN=mysql+pymysql://user:pass@host:3306/art_activity_collection

API_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Auth / JWT
AUTH_ENABLED=false
AUTH_REQUIRE_ALL_REQUESTS=false
AUTH_ISSUER=
AUTH_AUDIENCE=
AUTH_JWKS_URL=

# Rate limit (Redis optional; in-memory fallback when missing)
REDIS_URL=
RATE_LIMIT_GUEST_PER_MINUTE=30
RATE_LIMIT_GUEST_PER_DAY=500
RATE_LIMIT_USER_PER_MINUTE=120
RATE_LIMIT_USER_PER_DAY=5000

LOG_LEVEL=INFO

# Optional LLM fallback extraction
LLM_ENABLED=false
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=

# Optional crawler alert webhook (Zapier Catch Hook URL, etc.)
CRAWLER_ALERT_WEBHOOK_URL=

# Optional crawler batch config and schedule selector
CRAWLER_CONFIG_PATH=config/crawler_venues.toml
CRAWLER_BATCH_ID=

# Optional remote base URL for raw HTML storage (e.g. Cloudflare R2 public URL)
RAWHTML_BASE_URL=

# test
