{
  "expo": {
    "name": "Art Museum Activities",
    "slug": "art-museum-activities",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.thomasrchen.artmuseumactivities",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCalendarsFullAccessUsageDescription": "Lets you add museum activities you're interested in to your calendar."
      }
    },
    "android": {
      "package": "com.thomasrchen.artmuseumactivities",
      "adaptiveIcon": {
        "backgroundColor": "#F9EDDD",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F9EDDD",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Shows museums and art activities near your current location."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Lets you add museum activities you're interested in to your calendar."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "9004f01c-e146-46be-aecc-b922ba0e84d0"
      }
    },
    "owner": "trccoder"
  }
}
